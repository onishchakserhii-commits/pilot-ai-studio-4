
{
  "entities": {
    "BlogPost": {
      "title": "BlogPost",
      "description": "A blog article entry, potentially generated by AI as a draft.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "metaDescription": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "string", "enum": ["fr", "en", "ua"] },
        "status": { "type": "string", "enum": ["draft", "approved", "published"] },
        "author": { "type": "string" },
        "coverImage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "sourceTopic": { "type": "string" },
        "socialPost": { "type": "string" }
      },
      "required": ["title", "slug", "content", "language", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "blogPosts": {
      "schema": "#/entities/BlogPost",
      "description": "Collection of blog articles."
    }
  }
}
